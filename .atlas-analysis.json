  "keyFeatures": [
    "GitOps-native pipeline definitions stored in .tekton/ directory",
    "Multi-provider support (GitHub, GitLab, Bitbucket, Forgejo)",
    "Event-driven pipeline execution with CEL expressions",
    "ChatOps commands (/test, /retest, /cancel)",
    "Repository CRD for declarative configuration",
    "Inline task resolution from Tekton Hub and Artifact Hub",
    "Policy-based authorization with ok-to-test workflow",
    "Automatic cleanup and concurrency management",
    "GitHub Checks integration with detailed feedback",
    "tkn-pac CLI for bootstrap and management"
  ],
  "publicApiSurface": [
    "Repository CRD (pipelinesascode.tekton.dev/v1alpha1)",
    "tkn pac bootstrap - Initialize repository with PAC",
    "tkn pac create - Create Repository CR",
    "tkn pac generate - Generate pipeline templates",
    "tkn pac repository - Manage repositories",
    "tkn pac logs - View PipelineRun logs",
    "tkn pac describe - Describe PipelineRuns",
    "tkn pac resolve - Test pipeline resolution locally",
    "tkn pac webhook - Manage webhooks",
    "Controller webhook endpoint for Git events",
    "Incoming webhook endpoint for external triggers",
    "PipelineRun annotations (on-event, on-target-branch, on-cel-expression)",
    "Template variables (repo_url, revision, branch, etc.)",
    "GitOps commands (/test, /retest, /cancel, /ok-to-test)"
  ]
